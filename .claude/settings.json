{
  "allowedTools": [
    "Bash(npm *)",
    "Bash(npx *)",
    "Bash(uv *)",
    "Bash(git *)",
    "Bash(cd *)",
    "Bash(ls *)",
    "Bash(cat *)",
    "Bash(mkdir *)",
    "Bash(rm *)",
    "Bash(mv *)",
    "Bash(cp *)",
    "Bash(python *)",
    "Bash(gh *)",
    "Edit",
    "Write",
    "Read",
    "Glob",
    "Grep",
    "Task"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|Skill",
        "command": ".claude/hooks/log-tool-usage.sh",
        "async": true,
        "timeout": 5000
      }
    ]
  }
}
